# PostgreSQL — use Vercel Postgres, Supabase, Neon, or any PostgreSQL provider
DATABASE_URL="postgresql://user:password@host:5432/dbname?sslmode=require"

# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="generate-a-random-secret-with-openssl-rand-base64-32"

# Set to your production URL on Vercel (e.g. https://your-app.vercel.app)
NEXTAUTH_URL="http://localhost:3000"

ANTHROPIC_API_KEY="sk-ant-..."

# Optional — for sending invite emails automatically
# If not set, admin copies the invite link manually
SMTP_HOST=""
SMTP_PORT=""
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="team@aequora.digital"
